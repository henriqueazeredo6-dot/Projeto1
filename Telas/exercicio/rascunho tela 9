<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Exercícios</title>

<style>
body {
  margin: 0;
  display: flex;
  background: #000;
  color: white;
  font-family: 'Segoe UI', sans-serif;
}

/* SIDEBAR */
.sidebar {
  width: 240px;
  background: #000;
  padding: 20px;
  border-right: 1px solid #1f1f1f;
}

.aluno {
  margin-bottom: 30px;
  color: #aaa;
}

.menu a {
  display: block;
  padding: 10px;
  margin-bottom: 10px;
  color: white;
  text-decoration: none;
  border-radius: 8px;
}

.menu a:hover {
  background: #1a1a1a;
}

/* CONTEÚDO */
.main {
  flex: 1;
  padding: 30px;
}

/* TOPO */
.topo {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* BOTÃO */
.btn-add {
  background: #f97316;
  padding: 10px 16px;
  border-radius: 10px;
  color: white;
  text-decoration: none;
  font-weight: bold;
}

/* BUSCA */
.busca input {
  width: 250px;
  padding: 10px;
  background: #f97316;
  border: none;
  border-radius: 8px;
  color: white;
  margin-top: 20px;
}

/* CARD */
.card {
  background: #111;
  border: 1px solid #1f1f1f;
  border-radius: 12px;
  margin-top: 20px;
  padding: 12px 16px;
  width: 420px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.icon {
  font-size: 24px;
}

.nome {
  font-size: 15px;
  font-weight: bold;
}

.grupo {
  font-size: 12px;
  color: #aaa;
}

.acoes {
  display: flex;
  gap: 8px;
}

.btn {
  padding: 6px 8px;
  border-radius: 6px;
  text-decoration: none;
  color: white;
  font-size: 12px;
}

.video { background: #22c55e; }
.editar { background: #27272a; }
.deletar { background: #ef4444; }

/* MODAL */
#modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.95);
  display: none;
  justify-content: center;
  align-items: center;
}

#modal:target {
  display: flex;
}

.modal-box {
  background: #000;
  padding: 25px;
  border-radius: 12px;
  width: 420px;
  border: 1px solid #1f1f1f;
  position: relative;
}

.fechar {
  position: absolute;
  top: 10px;
  right: 15px;
  color: white;
  text-decoration: none;
}

/* FORM */
.form {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.form input,
.form select,
.form textarea {
  width: 100%;
  padding: 12px;
  border-radius: 10px;
  border: none;
  background: #1a1a1a;
  color: white;
}

.linha {
  display: flex;
  gap: 10px;
}

.form button {
  width: 100%;
  padding: 14px;
  background: #f97316;
  border: none;
  border-radius: 10px;
  color: white;
  font-weight: bold;
}
</style>

</head>

<body>

<!-- SIDEBAR -->
<div class="sidebar">
  <h2>Concierge Personal</h2>
  <div class="aluno">Aluno: João</div>

  <div class="menu">
    <a href="#">🏠 Dashboard</a>
    <a href="#">👥 Alunos</a>
    <a href="#">🏋️ Exercícios</a>
    <a href="#">📋 Treinos</a>
    <a href="#">📅 Agenda</a>
    <a href="#">💬 Mensagens</a>
    <a href="#">📝 Anamnese</a>
    <a href="#">💰 Financeiro</a>
  </div>
</div>

<!-- CONTEÚDO -->
<div class="main">

  <div class="topo">
    <div>
      <h1 style="margin-bottom:5px;">EXERCÍCIOS</h1>
      <p style="color:#aaa;">Exercícios no banco</p>
    </div>

    <a href="#modal" class="btn-add">+ Adicionar Exercício</a>
  </div>

  <div class="busca">
    <input type="text" placeholder="Buscar exercícios...">
  </div>

  <!-- CARD -->
  <div class="card">
    <div class="card-left">
      <div class="icon">🏋️</div>
      <div>
        <div class="nome">Supino reto</div>
        <div class="grupo">Peito</div>
      </div>
    </div>

    <div class="acoes">
      <a href="#" class="btn video">▶</a>
      <a href="#" class="btn editar">✏</a>
      <a href="#" class="btn deletar">🗑</a>
    </div>
  </div>

</div>

<!-- MODAL -->
<div id="modal">
  <div class="modal-box">

    <a href="#" class="fechar">✖</a>

    <h2>Novo Exercício</h2>

    <div class="form">

      <input type="text" placeholder="Nome do exercício">

      <div class="linha">
        <select>
          <option>Grupo muscular</option>
        </select>

        <select>
          <option>Dificuldade</option>
        </select>
      </div>

      <textarea placeholder="Descrição" style="height:80px;"></textarea>

      <div class="linha">
        <input type="text" placeholder="URL do vídeo">
        <input type="text" placeholder="URL da imagem">
      </div>

      <button>Salvar Exercício</button>

    </div>

  </div>
</div>

</body>
</html>